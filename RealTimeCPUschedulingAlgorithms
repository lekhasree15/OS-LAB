
#include <stdio.h>
#include <math.h>

#define MAX 20

typedef struct {
    int id;
    int burst;
    int deadline;
    int period;
    int share;
    int waiting;
    int turnaround;
    int completion;
} Process;

float calculate_utilization(Process p[], int n, int use_period) {
    float utilization = 0;
    for (int i = 0; i < n; i++) {
        utilization += (float)p[i].burst / (use_period ? p[i].period : p[i].deadline);
    }
    return utilization;
}

void edf(Process p[], int n) {
    float u = calculate_utilization(p, n, 0);
    printf("\n--- Earliest Deadline First (EDF) ---");
    printf("\nTotal Utilization: %.2f", u);

    if (u > 1.0) {
        printf("\nRESULT: NOT SCHEDULABLE (Utilization > 1)\n");
        return;
    }
    printf("\nRESULT: SCHEDULABLE\n");

    Process temp;
    for (int i = 0; i < n - 1; i++) {
        for (int j = i + 1; j < n; j++) {
            if (p[i].deadline > p[j].deadline) {
                temp = p[i];
                p[i] = p[j];
                p[j] = temp;
            }
        }
    }

    int time = 0;
    printf("ID\tBT\tDL\tCT\tWT\tTAT\n");
    for (int i = 0; i < n; i++) {
        p[i].waiting = time;
        time += p[i].burst;
        p[i].completion = time;
        p[i].turnaround = p[i].completion;
        printf("%d\t%d\t%d\t%d\t%d\t%d\n", p[i].id, p[i].burst, p[i].deadline, p[i].completion, p[i].waiting, p[i].turnaround);
    }
}

void rms(Process p[], int n) {
    float u = calculate_utilization(p, n, 1);
    float limit = n * (pow(2.0, 1.0/n) - 1);

    printf("\n--- Rate Monotonic Scheduling (RMS) ---");
    printf("\nTotal Utilization: %.2f (Limit: %.2f)", u, limit);

    if (u > 1.0) {
        printf("\nRESULT: DEFINITELY NOT SCHEDULABLE (Utilization > 1)\n");
        return;
    } else if (u > limit) {
        printf("\nRESULT: POTENTIALLY NOT SCHEDULABLE (Exceeds Liu-Layland Bound)\n");
    } else {
        printf("\nRESULT: SCHEDULABLE\n");
    }

    Process temp;
    for (int i = 0; i < n - 1; i++) {
        for (int j = i + 1; j < n; j++) {
            if (p[i].period > p[j].period) {
                temp = p[i];
                p[i] = p[j];
                p[j] = temp;
            }
        }
    }

    int time = 0;
    printf("ID\tBT\tPRD\tCT\tWT\tTAT\n");
    for (int i = 0; i < n; i++) {
        p[i].waiting = time;
        time += p[i].burst;
        p[i].completion = time;
        p[i].turnaround = p[i].completion;
        printf("%d\t%d\t%d\t%d\t%d\t%d\n", p[i].id, p[i].burst, p[i].period, p[i].completion, p[i].waiting, p[i].turnaround);
    }
}

void proportional(Process p[], int n) {
    int total_shares = 0;
    for(int i=0; i<n; i++) total_shares += p[i].share;

    printf("\n--- Proportional Share Scheduling ---");
    printf("\nTotal Shares Allocated: %d", total_shares);

    if (total_shares > 100) {
        printf("\nRESULT: OVERLOADED (Total shares > 100%%)\n");
    } else {
        printf("\nRESULT: SCHEDULABLE\n");
    }

    int time = 0;
    printf("ID\tBT\tShare\tCT\tWT\tTAT\n");
    for (int i = 0; i < n; i++) {
        p[i].waiting = time;
        time += p[i].burst;
        p[i].completion = time;
        p[i].turnaround = p[i].completion;
        printf("%d\t%d\t%d\t%d\t%d\t%d\n", p[i].id, p[i].burst, p[i].share, p[i].completion, p[i].waiting, p[i].turnaround);
    }
}

int main() {
    int n;
    Process p[MAX], p1[MAX], p2[MAX], p3[MAX];

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        p[i].id = i + 1;
        printf("\nProcess %d (Burst, Deadline, Period, Share): ", i + 1);
        scanf("%d %d %d %d", &p[i].burst, &p[i].deadline, &p[i].period, &p[i].share);
        p1[i] = p2[i] = p3[i] = p[i];
    }

    rms(p2, n);
    edf(p1, n);
    proportional(p3, n);

    return 0;
}

