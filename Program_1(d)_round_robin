#include <stdio.h>

struct Process {
    int pid;
    int at;
    int bt;
    int rem_bt;
    int ct;
    int wt;
    int tat;
};

int main() {
    int n, tq;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    struct Process p[n];

    for(int i = 0; i < n; i++) {
        p[i].pid = i + 1;

        printf("\nProcess %d\n", i + 1);

        printf("Arrival Time: ");
        scanf("%d", &p[i].at);

        printf("Burst Time: ");
        scanf("%d", &p[i].bt);

        p[i].rem_bt = p[i].bt;
    }

    printf("Enter Time Quantum: ");
    scanf("%d", &tq);

    int completed = 0;
    int time = 0;

    float total_wt = 0;
    float total_tat = 0;

    printf("\nGantt Chart:\n|");

    while(completed < n) {

        int found = 0;

        for(int i = 0; i < n; i++) {

            if(p[i].at <= time && p[i].rem_bt > 0) {

                found = 1;

                printf(" P%d |", p[i].pid);

                if(p[i].rem_bt > tq) {
                    time += tq;
                    p[i].rem_bt -= tq;
                }
                else {
                    time += p[i].rem_bt;

                    p[i].ct = time;
                    p[i].rem_bt = 0;

                    p[i].tat = p[i].ct - p[i].at;
                    p[i].wt = p[i].tat - p[i].bt;

                    total_wt += p[i].wt;
                    total_tat += p[i].tat;

                    completed++;
                }
            }
        }

        if(!found)
            time++;
    }

    printf("\n\n");

    printf("PID\tAT\tBT\tCT\tWT\tTAT\n");

    for(int i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\n",
               p[i].pid,
               p[i].at,
               p[i].bt,
               p[i].ct,
               p[i].wt,
               p[i].tat);
    }

    printf("\nAverage Waiting Time = %.2f",
           total_wt / n);

    printf("\nAverage Turnaround Time = %.2f\n",
           total_tat / n);

    return 0;
}
