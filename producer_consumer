#include<stdio.h>
#include<stdlib.h>

#define BUFFER_SIZE 5

int buffer[BUFFER_SIZE];
int in = 0, out = 0;

int mutex = 1;
int full = 0;
int empty = BUFFER_SIZE;

void wait(int *s){
  (*s)--;
}

int signal(int *s){
  return (*s)++;
}

void producer(int item){
  if(empty == 0){
    printf("Buffer is full\n");
    return;
  }
  wait(&empty);
  wait(&mutex);

  buffer[in] = item;
  printf("Produced: %d at buffer[%d]\n", item, in);
  in = (in + 1) % BUFFER_SIZE;

  signal(&mutex);
  signal(&full);

}

void consumer(){
  int item;
  if(full == 0){
    printf("Buffer is empty\n");
    return;
  }

  wait(&full);
  wait(&mutex);

  item = buffer[out];
  printf("Consumed: %d from buffer[%d]\n", item, out);
  out = (out + 1) % BUFFER_SIZE;

  signal(&mutex);
  signal(&empty);
}


int main(){
  int item = 0;
  for(int i = 0; i < 15; i++){
    producer(item++);
    if(i % 2 == 0){
      consumer();
    }
  }
  return 0;
}
