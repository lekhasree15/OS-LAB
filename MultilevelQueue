#include <stdio.h>
#include <string.h>

#define MAX 100

typedef struct {
    int pid;
    int arrival;
    int burst;
    int remaining;
    char type[10];
} Process;

typedef struct {
    int items[MAX];
    int front, rear;
} Queue;

void initQueue(Queue *q) {
    q->front = q->rear = -1;
}

int isEmpty(Queue *q) {
    return q->front == -1;
}

void enqueue(Queue *q, int value) {
    if (q->rear == MAX - 1) return;
    if (q->front == -1) q->front = 0;
    q->items[++q->rear] = value;
}

int dequeue(Queue *q) {
    if (isEmpty(q)) return -1;
    int val = q->items[q->front];
    if (q->front == q->rear)
        q->front = q->rear = -1;
    else
        q->front++;
    return val;
}

int main() {
    Process p[MAX];
    int n;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        printf("\nProcess %d\n", i + 1);
        p[i].pid = i + 1;

        printf("Arrival Time: ");
        scanf("%d", &p[i].arrival);

        printf("Burst Time: ");
        scanf("%d", &p[i].burst);

        printf("Type (system/user): ");
        scanf("%s", p[i].type);

        p[i].remaining = p[i].burst;
    }

    for (int i = 0; i < n - 1; i++) {
        for (int j = i + 1; j < n; j++) {
            if (p[i].arrival > p[j].arrival) {
                Process temp = p[i];
                p[i] = p[j];
                p[j] = temp;
            }
        }
    }

    Queue systemQueue, userQueue;
    initQueue(&systemQueue);
    initQueue(&userQueue);

    int current_time = 0, completed = 0, i = 0;
    int current_process = -1;

    int gantt[MAX], gtime[MAX];
    int gindex = 0;

    while (completed < n) {

        while (i < n && p[i].arrival <= current_time) {
            if (strcmp(p[i].type, "system") == 0)
                enqueue(&systemQueue, i);
            else
                enqueue(&userQueue, i);
            i++;
        }

        if (current_process != -1) {
            if (strcmp(p[current_process].type, "user") == 0 &&
                !isEmpty(&systemQueue)) {
                enqueue(&userQueue, current_process);
                current_process = -1;
            }
        }
        if (current_process == -1) {
            if (!isEmpty(&systemQueue))
                current_process = dequeue(&systemQueue);
            else if (!isEmpty(&userQueue))
                current_process = dequeue(&userQueue);
            else {
                current_time++;
                continue;
            }
        }
        gantt[gindex] = p[current_process].pid;
        gtime[gindex] = current_time;
        gindex++;
        p[current_process].remaining--;
        current_time++;

        if (p[current_process].remaining == 0) {
            printf("Process P%d completed at time %d\n",
                   p[current_process].pid, current_time);
            completed++;
            current_process = -1;
        }
    }

    printf("\nGantt Chart:\n");

    printf(" ");
    for (int k = 0; k < gindex; k++)
        printf("----");
    printf("\n|");

    for (int k = 0; k < gindex; k++)
        printf("P%d |", gantt[k]);

    printf("\n ");
    for (int k = 0; k < gindex; k++)
        printf("----");

    printf("\n%d", gtime[0]);
    for (int k = 1; k < gindex; k++)
        printf("   %d", gtime[k]);

    printf("   %d\n", current_time);

    return 0;
}
