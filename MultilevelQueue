#include <stdio.h>

struct Process {
    int pid;
    int at, bt;
    int ct, tat, wt;
};

void sortByAT(struct Process p[], int n) {
    int i, j;
    struct Process temp;

    for(i = 0; i < n - 1; i++) {
        for(j = 0; j < n - i - 1; j++) {
            if(p[j].at > p[j + 1].at) {
                temp = p[j];
                p[j] = p[j + 1];
                p[j + 1] = temp;
            }
        }
    }
}

int main() {
    int ns, nu, i;
    float avgWT = 0, avgTAT = 0;

    printf("Enter number of System Processes: ");
    scanf("%d", &ns);

    struct Process sys[ns];

    printf("\nEnter Arrival Time and Burst Time for System Processes:\n");
    for(i = 0; i < ns; i++) {
        sys[i].pid = i + 1;
        printf("P%d AT BT: ", sys[i].pid);
        scanf("%d%d", &sys[i].at, &sys[i].bt);
    }

    printf("\nEnter number of User Processes: ");
    scanf("%d", &nu);

    struct Process user[nu];

    printf("\nEnter Arrival Time and Burst Time for User Processes:\n");
    for(i = 0; i < nu; i++) {
        user[i].pid = i + 1;
        printf("U%d AT BT: ", user[i].pid);
        scanf("%d%d", &user[i].at, &user[i].bt);
    }

    sortByAT(sys, ns);
    sortByAT(user, nu);

    int time = 0;

    /* System Queue First */
    for(i = 0; i < ns; i++) {
        if(time < sys[i].at)
            time = sys[i].at;

        time += sys[i].bt;

        sys[i].ct = time;
        sys[i].tat = sys[i].ct - sys[i].at;
        sys[i].wt = sys[i].tat - sys[i].bt;

        avgWT += sys[i].wt;
        avgTAT += sys[i].tat;
    }

    /* User Queue Next */
    for(i = 0; i < nu; i++) {
        if(time < user[i].at)
            time = user[i].at;

        time += user[i].bt;

        user[i].ct = time;
        user[i].tat = user[i].ct - user[i].at;
        user[i].wt = user[i].tat - user[i].bt;

        avgWT += user[i].wt;
        avgTAT += user[i].tat;
    }

    printf("\nSYSTEM QUEUE (FCFS)\n");
    printf("PID\tAT\tBT\tCT\tTAT\tWT\n");

    for(i = 0; i < ns; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\n",
               sys[i].pid, sys[i].at, sys[i].bt,
               sys[i].ct, sys[i].tat, sys[i].wt);
    }

    printf("\nUSER QUEUE (FCFS)\n");
    printf("PID\tAT\tBT\tCT\tTAT\tWT\n");

    for(i = 0; i < nu; i++) {
        printf("U%d\t%d\t%d\t%d\t%d\t%d\n",
               user[i].pid, user[i].at, user[i].bt,
               user[i].ct, user[i].tat, user[i].wt);
    }

    int total = ns + nu;

    printf("\nAverage Turnaround Time = %.2f", avgTAT / total);
    printf("\nAverage Waiting Time = %.2f\n", avgWT / total);

    return 0;
}
