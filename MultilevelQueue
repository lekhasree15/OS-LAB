#include <stdio.h>
#include <limits.h>

struct Process {
    int pid;
    int at;
    int bt;
    int ct;
    int tat;
    int wt;
    int type;   // 0 = System, 1 = User
    int done;
};

int main() {
    int n;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    struct Process p[n];

    printf("\nEnter AT, BT and Type (0 = System, 1 = User)\n");

    for(int i = 0; i < n; i++) {
        p[i].pid = i + 1;

        printf("Process %d: ", i + 1);
        scanf("%d%d%d", &p[i].at, &p[i].bt, &p[i].type);

        p[i].done = 0;
    }

    int time = 0;
    int completed = 0;

    while(completed < n) {

        int idx = -1;
        int earliestAT = INT_MAX;

        /* Search System Queue First */
        for(int i = 0; i < n; i++) {
            if(!p[i].done &&
               p[i].type == 0 &&
               p[i].at <= time) {

                if(p[i].at < earliestAT) {
                    earliestAT = p[i].at;
                    idx = i;
                }
            }
        }

        /* If no System process is ready, search User Queue */
        if(idx == -1) {
            earliestAT = INT_MAX;

            for(int i = 0; i < n; i++) {
                if(!p[i].done &&
                   p[i].type == 1 &&
                   p[i].at <= time) {

                    if(p[i].at < earliestAT) {
                        earliestAT = p[i].at;
                        idx = i;
                    }
                }
            }
        }

        /* CPU Idle */
        if(idx == -1) {
            time++;
            continue;
        }

        time += p[idx].bt;

        p[idx].ct = time;
        p[idx].tat = p[idx].ct - p[idx].at;
        p[idx].wt = p[idx].tat - p[idx].bt;

        p[idx].done = 1;
        completed++;
    }

    float avgWT = 0, avgTAT = 0;

    printf("\nPID\tType\tAT\tBT\tCT\tTAT\tWT\n");

    for(int i = 0; i < n; i++) {

        printf("P%d\t%s\t%d\t%d\t%d\t%d\t%d\n",
               p[i].pid,
               (p[i].type == 0) ? "System" : "User",
               p[i].at,
               p[i].bt,
               p[i].ct,
               p[i].tat,
               p[i].wt);

        avgWT += p[i].wt;
        avgTAT += p[i].tat;
    }

    printf("\nAverage Turnaround Time = %.2f", avgTAT / n);
    printf("\nAverage Waiting Time = %.2f\n", avgWT / n);

    return 0;
}
