#include <stdio.h>

#define MAX 50

typedef struct {
    int pid;
    int arrival;
    int burst;
    int waiting;
    int turnaround;
} Process;

void fcfs(Process p[], int n, int start_time) {
    int time = start_time;

    for (int i = 0; i < n; i++) {
        if (time < p[i].arrival)
            time = p[i].arrival;

        p[i].waiting = time - p[i].arrival;
        time += p[i].burst;
        p[i].turnaround = p[i].waiting + p[i].burst;
    }

    printf("\nPID\tArrival\tBurst\tWaiting\tTurnaround\n");
    for (int i = 0; i < n; i++) {
        printf("%d\t%d\t%d\t%d\t%d\n",
               p[i].pid, p[i].arrival, p[i].burst,
               p[i].waiting, p[i].turnaround);
    }
}

int main() {
    Process system[MAX], user[MAX];
    int n_sys, n_user;

    printf("Enter number of SYSTEM processes: ");
    scanf("%d", &n_sys);

    for (int i = 0; i < n_sys; i++) {
        printf("\nSystem Process %d\n", i + 1);
        system[i].pid = i + 1;
        printf("Arrival Time: ");
        scanf("%d", &system[i].arrival);
        printf("Burst Time: ");
        scanf("%d", &system[i].burst);
    }

    printf("\nEnter number of USER processes: ");
    scanf("%d", &n_user);

    for (int i = 0; i < n_user; i++) {
        printf("\nUser Process %d\n", i + 1);
        user[i].pid = i + 1;
        printf("Arrival Time: ");
        scanf("%d", &user[i].arrival);
        printf("Burst Time: ");
        scanf("%d", &user[i].burst);
    }

    printf("\n--- SYSTEM PROCESS QUEUE (Higher Priority) ---\n");
    fcfs(system, n_sys, 0);

    int time = 0;
    for (int i = 0; i < n_sys; i++) {
        if (time < system[i].arrival)
            time = system[i].arrival;
        time += system[i].burst;
    }

    printf("\n--- USER PROCESS QUEUE (Lower Priority) ---\n");
    fcfs(user, n_user, time);

    return 0;
}
