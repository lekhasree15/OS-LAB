#include<stdio.h>

struct process
{
    int pid,at,bt,pri,ct,tat,wt,done;
};

int main()
{
    int n,i,time=0,completed=0,highest,idx;

    printf("Enter number of processes: ");
    scanf("%d",&n);

    struct process p[n];

    for(i=0;i<n;i++)
    {
        p[i].pid=i+1;
        printf("\nEnter Arrival Time of P%d: ",i+1);
        scanf("%d",&p[i].at);

        printf("Enter Burst Time of P%d: ",i+1);
        scanf("%d",&p[i].bt);

        printf("Enter Priority of P%d: ",i+1);
        scanf("%d",&p[i].pri);

        p[i].done=0;
    }

    printf("\nGantt Chart:\n");

    while(completed<n)
    {
        highest=9999;

        for(i=0;i<n;i++)
        {
            if(p[i].at<=time && p[i].done==0 && p[i].pri<highest)
            {
                highest=p[i].pri;
                idx=i;
            }
        }

        printf("| P%d ",p[idx].pid);

        time+=p[idx].bt;

        p[idx].ct=time;
        p[idx].tat=p[idx].ct-p[idx].at;
        p[idx].wt=p[idx].tat-p[idx].bt;

        p[idx].done=1;
        completed++;
    }

    printf("|\n\n");

    printf("PID\tAT\tBT\tPRI\tCT\tTAT\tWT\n");

    for(i=0;i<n;i++)
    {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\t%d\n",
        p[i].pid,p[i].at,p[i].bt,p[i].pri,p[i].ct,p[i].tat,p[i].wt);
    }

    return 0;
}
